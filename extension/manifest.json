{
  "manifest_version": 3,
  "name": "Meeting Translator",
  "version": "1.0",
  "description": "Real-time meeting translator",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "host_permissions": [
    "http://localhost:8000/*"
  ]
}